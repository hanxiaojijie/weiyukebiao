view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 36rpx;
  background:
    radial-gradient(circle at top right, var(--page-bg-gradient-top, rgba(248, 188, 204, 0.24)), transparent 28%),
    linear-gradient(180deg, var(--page-bg-gradient-start, #fff7f8) 0%, var(--page-bg-gradient-end, #fff1f3) 100%);
}

.hero-card,
.panel-card,
.list-card,
.action-card {
  background: var(--card-bg, #fffafb);
  border: 1rpx solid var(--card-border, rgba(166, 77, 103, 0.1));
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx var(--card-shadow, rgba(166, 77, 103, 0.08));
}

.hero-card {
  padding: 24rpx 24rpx 22rpx;
  background: linear-gradient(145deg, var(--hero-bg-start, #fffdfd) 0%, var(--hero-bg-end, #ffe4ea) 100%);
}

.page-kicker {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--text-muted, #b07d8c);
  text-transform: uppercase;
}

.page-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 600;
  color: var(--text-strong, #5d3344);
}

.page-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary, #866370);
}

.metric-row {
  display: flex;
  gap: 20rpx;
  margin-top: 18rpx;
}

.metric-pill {
  flex: 1;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: var(--pill-bg, rgba(243, 189, 202, 0.28));
}

.metric-label {
  font-size: 22rpx;
  color: var(--text-muted, #9a7380);
}

.metric-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--accent-strong, #a64d67);
}

.section {
  margin-top: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 0 6rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-strong, #5d3344);
}

.section-meta {
  font-size: 20rpx;
  color: var(--text-muted, #af8a96);
}

.panel-card,
.list-card,
.action-card {
  padding: 20rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--accent-soft, #fde6eb);
  color: var(--accent-soft-text, #96445c);
  font-size: 22rpx;
}

.tag-warm {
  background: var(--warm-bg, #ffe7d8);
  color: var(--warm-text, #a76043);
}

.tag-muted {
  background: #eceef3;
  color: #677086;
}

.tag-danger {
  background: #f8dde0;
  color: #b45264;
}

.list-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--divider-color, rgba(166, 77, 103, 0.08));
}

.list-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-strong, #5b3141);
}

.item-subtitle,
.item-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary, #8c6774);
}

.cta-row {
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 78rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.2;
  padding: 0 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent-mid, #c85f7f) 0%, var(--accent-strong, #a64d67) 100%);
  color: #ffffff;
}

.btn-secondary {
  background: var(--secondary-btn-bg, #fdecef);
  color: var(--secondary-btn-text, #9c4961);
}

.progress-track {
  margin-top: 14rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f7ead0 0%, #ecd6a0 100%);
  box-shadow: inset 0 2rpx 6rpx rgba(157, 120, 28, 0.08);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(
    90deg,
    #f8e8b2 0%,
    #e0be62 45%,
    #c79a37 100%
  );
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5),
    0 6rpx 14rpx rgba(178, 134, 34, 0.18);
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-muted, #af8a96);
  line-height: 1.7;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.mini-stat {
  padding: 18rpx;
  border-radius: 24rpx;
  background: var(--mini-stat-bg, #fff6f8);
  border: 1rpx solid var(--divider-color, rgba(166, 77, 103, 0.08));
  min-width: 0;
}

.theme-picker {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.theme-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--divider-color, rgba(166, 77, 103, 0.08));
}

.theme-option:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.theme-preview {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.06);
}

.theme-preview.theme-strawberry {
  background: linear-gradient(135deg, #ffcad7 0%, #c85f7f 100%);
}

.theme-preview.theme-forest {
  background: linear-gradient(135deg, #d9ebdc 0%, #5f8d6c 100%);
}

.theme-preview.theme-ocean {
  background: linear-gradient(135deg, #dcecf8 0%, #5c8eb9 100%);
}

.theme-preview.theme-caramel {
  background: linear-gradient(135deg, #f8ead6 0%, #c48b62 100%);
}

.theme-preview.theme-graphite {
  background: linear-gradient(135deg, #eceef3 0%, #7b8498 100%);
}

.theme-preview.theme-midnight {
  background: linear-gradient(135deg, #2b2f39 0%, #f1d17a 100%);
}

.theme-preview.theme-lavender {
  background: linear-gradient(135deg, #efe8fa 0%, #9b87c2 100%);
}

.theme-preview.theme-mint {
  background: linear-gradient(135deg, #e5f7f1 0%, #6cb39c 100%);
}

.theme-preview.theme-ruby {
  background: linear-gradient(135deg, #f8e4ea 0%, #b46479 100%);
}

.theme-preview.theme-sand {
  background: linear-gradient(135deg, #f8f0dd 0%, #c59a4f 100%);
}

.theme-option-copy {
  flex: 1;
}

.theme-check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: var(--accent-soft, #fde6eb);
  color: var(--accent-strong, #a64d67);
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-stat-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent-strong, #a64d67);
}

.mini-stat-label {
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.4;
  color: var(--text-muted, #af8a96);
}

.subtle-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-strong, #5d3344);
}

.subtle-copy {
  font-size: 20rpx;
  color: var(--text-muted, #af8a96);
}

.reward-card {
  padding: 26rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(224, 189, 93, 0.16), transparent 34%),
    linear-gradient(145deg, #fffef9 0%, #fff8eb 38%, #fdf0d7 100%);
  border: 1rpx solid rgba(201, 165, 78, 0.22);
  box-shadow:
    0 22rpx 42rpx rgba(166, 77, 103, 0.06),
    0 12rpx 28rpx rgba(201, 165, 78, 0.12);
}

.theme-midnight .reward-card {
  background:
    radial-gradient(circle at top right, rgba(241, 209, 122, 0.18), transparent 34%),
    linear-gradient(145deg, #2b2417 0%, #211b12 42%, #18140f 100%);
  border: 1rpx solid rgba(241, 209, 122, 0.16);
  box-shadow:
    0 22rpx 42rpx rgba(0, 0, 0, 0.24),
    0 12rpx 28rpx rgba(201, 165, 78, 0.12);
}

.theme-midnight .reward-percent {
  background:
    linear-gradient(145deg, #58441f 0%, #3c2f18 58%, #2d2414 100%);
  border: 1rpx solid rgba(241, 209, 122, 0.18);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 244, 212, 0.14),
    0 10rpx 22rpx rgba(0, 0, 0, 0.18);
}

.theme-midnight .reward-percent-value {
  color: #f4d98c;
}

.theme-midnight .reward-percent-label {
  color: #d5bd79;
}

.theme-midnight .progress-track {
  background: linear-gradient(90deg, #3b2f1a 0%, #2b2113 100%);
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.24);
}

.theme-midnight .progress-fill {
  background: linear-gradient(90deg, #f5e0a0 0%, #ddb95a 45%, #b98b2b 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 244, 212, 0.24),
    0 6rpx 14rpx rgba(0, 0, 0, 0.2);
}

.theme-midnight .reward-metric {
  background: rgba(255, 242, 212, 0.06);
}

.reward-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.reward-percent {
  min-width: 126rpx;
  padding: 18rpx 16rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, #fff7cf 0%, #f4d77d 28%, #caa44b 58%, #f7e4a3 82%, #fff6d6 100%);
  border: 1rpx solid rgba(170, 129, 28, 0.22);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.55),
    0 10rpx 22rpx rgba(172, 131, 34, 0.16);
  text-align: center;
}

.reward-percent-value {
  font-size: 42rpx;
  line-height: 1;
  font-weight: 700;
  color: #8d6516;
}

.reward-percent-label {
  margin-top: 8rpx;
  font-size: 18rpx;
  color: #9a761f;
}

.reward-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.reward-metric {
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 251, 240, 0.72);
}

.reward-metric-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-strong, #5d3344);
}

.reward-metric-label {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: var(--text-muted, #af8a96);
}

.week-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.week-board {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.week-day-card {
  padding: 18rpx;
  border-radius: 24rpx;
  background: var(--card-bg, #fffafb);
  border: 1rpx solid var(--divider-color, rgba(166, 77, 103, 0.08));
}

.week-day-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.week-day-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-strong, #5d3344);
}

.week-day-slots {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.slot-chip {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: var(--accent-soft, #fde6eb);
}

.slot-time {
  font-size: 20rpx;
  color: var(--accent-soft-text, #96445c);
}

.slot-title {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-strong, #5d3344);
}

.slot-empty {
  font-size: 20rpx;
  color: var(--text-muted, #af8a96);
}

.limit-banner {
  padding: 18rpx;
  border-radius: 22rpx;
  background: var(--warm-bg, #ffe7d8);
  color: var(--warm-text, #a76043);
  font-size: 22rpx;
  line-height: 1.6;
}

.session-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: var(--card-bg, #fffafb);
  border: 1rpx solid var(--card-border, rgba(166, 77, 103, 0.1));
  box-shadow: 0 16rpx 30rpx var(--card-shadow, rgba(166, 77, 103, 0.08));
}

.session-stage {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--accent-soft, #fde6eb);
  color: var(--accent-soft-text, #96445c);
  font-size: 22rpx;
}

.session-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.form-card {
  padding: 28rpx 24rpx;
  background: var(--card-bg, #fffafb);
  border-radius: 28rpx;
  border: 1rpx solid var(--card-border, rgba(166, 77, 103, 0.1));
}

.form-item + .form-item {
  margin-top: 22rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--text-secondary, #8c6774);
  margin-bottom: 12rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  background: var(--input-bg, #fff1f4);
  border-radius: 20rpx;
  padding: 24rpx 22rpx;
  font-size: 28rpx;
  color: var(--text-strong, #5b3141);
}

.form-input {
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.form-textarea {
  min-height: 220rpx;
}

.course-color-sage {
  background: #dde7df;
  color: #4f6655;
  border-left-color: #7f9c86;
}

.course-color-blue {
  background: #dde6ee;
  color: #53697a;
  border-left-color: #87a2b7;
}

.course-color-plum {
  background: #e8dfea;
  color: #68556c;
  border-left-color: #9a83a4;
}

.course-color-teal {
  background: #dce7e8;
  color: #4d686a;
  border-left-color: #7ea3a7;
}

.course-color-olive {
  background: #e6e5da;
  color: #666453;
  border-left-color: #a29f7d;
}
