<view class="page-shell theme-{{themeKey}}">
  <view class="hero-card">
    <view class="page-kicker">未雨课表</view>
    <view class="page-title">一个主奖励，承接长期动力。</view>
    <view class="page-desc">主奖励会跟随学分自动推进。</view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
  </view>

  <view class="section">
    <view class="form-card">
      <view class="form-item">
        <view class="form-label">奖励名称</view>
        <input class="form-input" placeholder="例如：LV 包包" value="{{form.title}}" data-field="title" bindinput="onInputChange" />
      </view>
      <view class="form-item">
        <view class="form-label">目标学分</view>
        <input class="form-input" placeholder="例如：188" value="{{form.targetCredits}}" data-field="targetCredits" bindinput="onInputChange" />
      </view>
      <view class="form-item">
        <view class="form-label">奖励说明</view>
        <textarea class="form-textarea" placeholder="记录为什么想要它，它代表什么阶段成果" value="{{form.description}}" data-field="description" bindinput="onInputChange"></textarea>
      </view>
      <view class="cta-row">
        <button class="btn-primary" bindtap="onSaveReward" loading="{{saving}}">保存奖励</button>
        <button class="btn-secondary" bindtap="goBack">返回上一页</button>
      </view>
    </view>
  </view>
</view>
