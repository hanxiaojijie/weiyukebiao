.theme-picker {
  margin-top: 4rpx;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 18rpx 12rpx;
}

.theme-swatch {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.theme-swatch .theme-preview {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 22rpx;
}

.theme-swatch-name {
  font-size: 20rpx;
  color: var(--text-secondary, #866370);
  text-align: center;
  line-height: 1.3;
}

.theme-check-floating {
  position: absolute;
  top: -8rpx;
  right: -2rpx;
}
