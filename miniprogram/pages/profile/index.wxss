.list-item {
  padding-right: 8rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft, #fde6eb);
  color: var(--accent-strong, #a64d67);
  font-size: 34rpx;
  font-weight: 600;
}

.profile-avatar-image {
  width: 100%;
  height: 100%;
}

.profile-copy {
  min-width: 0;
  flex: 1;
}
