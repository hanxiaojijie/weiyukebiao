.profile-inline {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-inline-input {
  flex: 1;
  min-height: 88rpx;
  background: var(--input-bg, #fff1f4);
  border-radius: 20rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: var(--text-strong, #5b3141);
}

.avatar-picker {
  width: 116rpx;
  height: 116rpx;
  min-width: 116rpx;
  min-height: 116rpx;
  flex: 0 0 116rpx;
  align-self: flex-start;
  border-radius: 999rpx;
  padding: 0;
  overflow: hidden;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.avatar-image,
.avatar-fallback {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft, #fde6eb);
  color: var(--accent-strong, #a64d67);
  font-size: 42rpx;
  font-weight: 600;
}
